# ============================================================
#  VodiySoft UserBot — Konfiguratsiya fayli
#  Bu faylni nusxa ko'chiring: copy .env.example .env
#  va qiymatlarni to'ldiring
# ============================================================

# ------------------------------------------------------------------
# TELEGRAM API  →  https://my.telegram.org/auth  (Apps bo'limi)
# ------------------------------------------------------------------
API_ID=your_api_id_here
API_HASH=your_api_hash_here
PHONE_NUMBER=+998XXXXXXXXX

# ------------------------------------------------------------------
# OPENAI API  →  https://platform.openai.com/api-keys
# ------------------------------------------------------------------
OPENAI_API_KEY=sk-proj-...

# ------------------------------------------------------------------
# ELEVENLABS API  →  https://elevenlabs.io/app/settings/api-keys
# Text-to-Speech (TTS) uchun ishlatiladi
# ------------------------------------------------------------------
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# ------------------------------------------------------------------
# MODEL SOZLAMALARI
# Mavjud: gpt-4o | gpt-4o-mini | gpt-4.1 | gpt-4.5
# o-seriya (o1, o3, o4-mini) — temperature avtomatik o'chiriladi
# ------------------------------------------------------------------
GPT_MODEL=gpt-4o
GPT_MAX_TOKENS=500

# ------------------------------------------------------------------
# XULQ-ATVOR SOZLAMALARI
# ------------------------------------------------------------------
# Suhbat xotirasida nechta xabar saqlansin (har bir chat uchun)
MAX_HISTORY=25

# Javob yuborishdan oldin kutish vaqti (sekund) — tabiiy ko'rinish uchun
RESPONSE_DELAY_MIN=2.0
RESPONSE_DELAY_MAX=5.5

# Bir chatda ikki javob orasidagi minimal vaqt (sekund)
RATE_LIMIT_SECONDS=25

# Bir daqiqada maksimal javoblar soni (global, ban oldini olish)
MAX_RESPONSES_PER_MINUTE=15

# ------------------------------------------------------------------
# QAYERDA JAVOB BERSIN  (true / false)
# ------------------------------------------------------------------
RESPOND_IN_PRIVATE=true
RESPOND_IN_GROUPS=true
RESPOND_IN_CHANNELS=true
